[Unit]
Description=CLIProxyAPI-cleaner artifact retention cleanup
After=local-fs.target

[Service]
Type=oneshot
WorkingDirectory=/opt/CLIProxyAPI-cleaner
ExecStart=/bin/sh /opt/CLIProxyAPI-cleaner/run_retention.sh
User=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/root /var/log /tmp /opt/CLIProxyAPI-cleaner

